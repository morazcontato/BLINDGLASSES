# ============================================
# BLIND - Variaveis de ambiente
# ============================================
# Copie este arquivo para .env.local e preencha

# WhatsApp (numero completo com codigo do pais)
NEXT_PUBLIC_WHATSAPP_NUMBER=5500000000000

# Instagram
NEXT_PUBLIC_INSTAGRAM_HANDLE=blind.glasses

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta Pixel
# NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# URL do site (para Open Graph)
# NEXT_PUBLIC_SITE_URL=https://seudominio.com.br
